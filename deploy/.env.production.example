# ============================================================================
# «Кадр» — переменные окружения для ПРОДА (self-hosted Supabase, РФ-облако).
# Скопируй в deploy/.env.production и заполни. НЕ коммить заполненный файл.
# Все значения — секреты; генерируй сильные (openssl rand -hex 32).
# ============================================================================

# ---- Домены (РФ) -----------------------------------------------------------
# Публичный домен API (Supabase за reverse-proxy с TLS).
API_EXTERNAL_URL=https://api.kadr.ru
# Домен гостевого PWA.
SITE_URL=https://kadr.ru
# Список разрешённых origin для CORS Edge Functions (через запятую).
ALLOWED_ORIGINS=https://kadr.ru,https://www.kadr.ru

# ---- Postgres --------------------------------------------------------------
POSTGRES_PASSWORD=ЗАМЕНИ_сильный_пароль
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# ---- JWT / ключи Supabase --------------------------------------------------
# JWT_SECRET: openssl rand -hex 32  (мин. 32 символа).
JWT_SECRET=ЗАМЕНИ_jwt_secret_min_32_chars
# ANON_KEY и SERVICE_ROLE_KEY генерируются из JWT_SECRET (см. DEPLOY.md, шаг «Ключи»).
ANON_KEY=ЗАМЕНИ_anon_jwt
SERVICE_ROLE_KEY=ЗАМЕНИ_service_role_jwt

# ---- Storage (S3 РФ: Yandex Object Storage / VK Cloud S3) ------------------
# Supabase Storage в режиме S3-backend ИЛИ file-backend. Для РФ — S3 в РФ-регионе.
STORAGE_BACKEND=s3
S3_ENDPOINT=https://storage.yandexcloud.net
S3_REGION=ru-central1
S3_BUCKET=kadr-event-photos
S3_ACCESS_KEY=ЗАМЕНИ
S3_SECRET_KEY=ЗАМЕНИ
# Шифрование at-rest включить на стороне Object Storage (152-ФЗ).

# ---- Edge Functions (секреты, читаются функциями) -------------------------
# Признак прода: отключает localhost-fallback в toPublicUrl.
KADR_ENV=production
# Публичный URL Storage (через какой домен отдаются подписанные URL фото).
PUBLIC_STORAGE_URL=https://api.kadr.ru
# База join-ссылки в QR (create-event).
JOIN_BASE_URL=https://kadr.ru
# Секрет для служебного вызова purge-expired (cron). openssl rand -hex 32.
# ВАЖНО: продублировать в БД: update app_config set value='<этот секрет>' where key='purge_secret';
PURGE_SECRET=ЗАМЕНИ_purge_secret
# Внутренний URL функции purge-expired для cron (через pg_net). Обычно:
# https://api.kadr.ru/functions/v1/purge-expired — продублировать в app_config.purge_url.

# ---- Auth: российский SMS-провайдер (SMS Aero / SMSC) ----------------------
# OTP хоста на проде — через кастомный Auth hook к российскому провайдеру.
SMS_PROVIDER=smsaero
SMS_API_LOGIN=ЗАМЕНИ
SMS_API_KEY=ЗАМЕНИ

# ---- SMTP для email (опционально, РФ) --------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER=no-reply@kadr.ru

# ---- Аналитика (только российская) -----------------------------------------
# AppMetrica / Яндекс.Метрика. НЕ Google/Firebase.
YANDEX_METRIKA_ID=

# ---- Web (build-time, NEXT_PUBLIC_*) ---------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://api.kadr.ru
NEXT_PUBLIC_SUPABASE_ANON_KEY=ЗАМЕНИ_anon_jwt
NEXT_PUBLIC_POLICY_VERSION=2026-06-01
